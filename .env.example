# ──────────────────────────────────────
# Supabase
# ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ──────────────────────────────────────
# App URL
# ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Supabase Auth (Google OAuth): add this exact URL under Redirect URLs in the dashboard:
#   ${NEXT_PUBLIC_APP_URL}/auth/callback

# ──────────────────────────────────────
# LLM Providers (configure at least one)
# ──────────────────────────────────────

# OpenAI (recommended default)
OPENAI_API_KEY=
OPENAI_BASE_URL=                        # optional, for OpenAI-compatible proxies

# OpenAI text models (used when OPENAI_API_KEY is set)
# OPENAI_INTERVIEW_GENERATION_MODEL=gpt-4o-mini
# OPENAI_REPORT_ANALYSIS_MODEL=gpt-4o
# OPENAI_CHAT_INTERVIEW_MODEL=gpt-4o-mini
# OPENAI_QUESTION_REFINEMENT_MODEL=gpt-4o-mini

# Moonshot Kimi (alternative)
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# MiniMax (alternative)
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ──────────────────────────────────────
# Voice Relay
# ──────────────────────────────────────
VOICE_RELAY_PORT=8081
OPENAI_VOICE_RELAY_PORT=8082

# Voice relay URLs (used by the frontend)
NEXT_PUBLIC_VOICE_RELAY_URL=ws://localhost:8081
NEXT_PUBLIC_OPENAI_VOICE_RELAY_URL=ws://localhost:8082

# Which voice relay to use as primary: "auto" | "voice" | "openai"
# NEXT_PUBLIC_VOICE_RELAY_PRIMARY=auto

# ──────────────────────────────────────
# Voice Relay LLM (for in-relay summarization)
# ──────────────────────────────────────
# Falls back to KIMI/MINIMAX keys if not set
# RELAY_LLM_API_KEY=
# RELAY_LLM_BASE_URL=
# RELAY_LLM_MODEL=

# ──────────────────────────────────────
# OpenAI Direct Realtime (server/openai-voice-relay.ts default)
# ──────────────────────────────────────
# Requires OPENAI_REALTIME_API_KEY or OPENAI_API_KEY unless USE_AZURE_OPENAI_REALTIME=true
# OPENAI_REALTIME_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# OPENAI_REALTIME_VOICE=alloy
# OPENAI_REALTIME_WS_URL=wss://api.openai.com/v1/realtime

# ASR / transcription inside Realtime session
# VOICE_ASR_PRIMARY=openai
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=whisper-1

# User transcript commit gating (openai-voice-relay.ts)
# VOICE_MIN_COMMIT_WORDS=8
# VOICE_MIN_COMMIT_CHARS=40
# VOICE_FRAGMENT_MERGE_MS=4000
# VOICE_COACH_FRAGMENT_MERGE_MS=5000

# ──────────────────────────────────────
# Azure OpenAI Realtime (voice relay alternate)
# ──────────────────────────────────────
# USE_AZURE_OPENAI_REALTIME=true
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-realtime-1.5
# AZURE_OPENAI_VOICE=ash

# ──────────────────────────────────────
# Volcengine Doubao (Chinese voice relay)
# ──────────────────────────────────────
# DOUBAO_APP_ID=
# DOUBAO_ACCESS_TOKEN=
# DOUBAO_SECRET_KEY=
# DOUBAO_APP_KEY=
# DOUBAO_RESOURCE_ID=
# DOUBAO_WS_URL=
# DOUBAO_VOICE_EN=
# DOUBAO_VOICE_ZH=

# ──────────────────────────────────────
# Optional
# ──────────────────────────────────────
# LOG_LEVEL=info
