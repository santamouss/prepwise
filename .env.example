# ──────────────────────────────────────
# Supabase
# ──────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ──────────────────────────────────────
# App URL
# ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────
# LLM Providers (configure at least one)
# ──────────────────────────────────────

# OpenAI (recommended default)
OPENAI_API_KEY=
OPENAI_BASE_URL=                        # optional, for OpenAI-compatible proxies

# Moonshot Kimi (alternative)
# KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# MiniMax (alternative)
# MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ──────────────────────────────────────
# Voice Relay
# ──────────────────────────────────────
VOICE_RELAY_PORT=8081
OPENAI_VOICE_RELAY_PORT=8082

# Voice relay URLs (used by the frontend)
NEXT_PUBLIC_VOICE_RELAY_URL=ws://localhost:8081
NEXT_PUBLIC_OPENAI_VOICE_RELAY_URL=ws://localhost:8082

# Which voice relay to use as primary: "auto" | "voice" | "openai"
# NEXT_PUBLIC_VOICE_RELAY_PRIMARY=auto

# ──────────────────────────────────────
# Voice Relay LLM (for in-relay summarization)
# ──────────────────────────────────────
# Falls back to KIMI/MINIMAX keys if not set
# RELAY_LLM_API_KEY=
# RELAY_LLM_BASE_URL=
# RELAY_LLM_MODEL=

# ASR provider for OpenAI voice relay: "openai" (default)
# VOICE_ASR_PRIMARY=openai
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=whisper-1

# ──────────────────────────────────────
# Azure OpenAI Realtime (for voice relay)
# ──────────────────────────────────────
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-realtime-preview
# AZURE_OPENAI_VOICE=alloy

# ──────────────────────────────────────
# Volcengine Doubao (Chinese voice relay)
# ──────────────────────────────────────
# DOUBAO_APP_ID=
# DOUBAO_ACCESS_TOKEN=
# DOUBAO_SECRET_KEY=
# DOUBAO_APP_KEY=
# DOUBAO_RESOURCE_ID=
# DOUBAO_WS_URL=
# DOUBAO_VOICE_EN=
# DOUBAO_VOICE_ZH=

# ──────────────────────────────────────
# Optional
# ──────────────────────────────────────
# LOG_LEVEL=info
